ANTHROPIC_API_KEY=
SECRET_KEY=generate-a-strong-secret-here
DB_PATH=vello.db
CORS_ORIGIN=https://vello.flexflows.net
KORTEX_API_URL=https://kortex.flexflows.net/api/v1

# Email briefings — get key at resend.com
RESEND_API_KEY=
BRIEFING_FROM=Vello <briefing@vello.flexflows.net>
APP_URL=https://vello.flexflows.net

# LLM provider — defaults to Anthropic/Claude.
# To use Hermes or any OpenAI-compatible model instead:
#
#   Together AI (Hermes-3 8B fast, 70B quality)
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.together.xyz/v1
#   LLM_API_KEY=<together-key>
#   DIALOGUE_MODEL=NousResearch/Hermes-3-Llama-3.1-8B
#   AGENT_MODEL=NousResearch/Hermes-3-Llama-3.1-70B
#
#   Fireworks AI
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.fireworks.ai/inference/v1
#   LLM_API_KEY=<fireworks-key>
#   DIALOGUE_MODEL=accounts/fireworks/models/hermes-3-llama-3-1-8b
#   AGENT_MODEL=accounts/fireworks/models/hermes-3-llama-3-1-70b
#
#   Ollama (local)
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_API_KEY=ollama
#   DIALOGUE_MODEL=hermes3
#   AGENT_MODEL=hermes3:70b
#
LLM_PROVIDER=anthropic
LLM_BASE_URL=
LLM_API_KEY=
DIALOGUE_MODEL=claude-haiku-4-5-20251001
AGENT_MODEL=claude-sonnet-4-6

# ── Integrations (all optional — agent degrades gracefully when absent) ────────

# Google Calendar — create OAuth credentials at console.cloud.google.com
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
# GCAL_REDIRECT_URI defaults to APP_URL/api/v1/auth/oauth/google/callback

# Twilio SMS — get credentials at twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=     # E.164 format e.g. +14155552671

# OpenWeather — get free key at openweathermap.org/api
OPENWEATHER_API_KEY=

# Google Maps Geocoding — enable Geocoding API at console.cloud.google.com
GMAPS_API_KEY=

# AfterShip package tracking — get key at aftership.com
AFTERSHIP_API_KEY=

# Web Push (VAPID) — generate a key pair:
#   npx web-push generate-vapid-keys
# Or: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); import base64; print('Private:', base64.urlsafe_b64encode(v.private_key.private_bytes_raw()).decode()); print('Public:', base64.urlsafe_b64encode(v.public_key.public_bytes_raw()).decode())"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
# VAPID_SUBJECT defaults to mailto: from BRIEFING_FROM
